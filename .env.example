# ===========================================
# DreamLabs Environment Variables Template
# ===========================================
# Copy this file to .env and fill in your values

# -------------------------------------------
# ALIBABA CLOUD MODEL STUDIO (Qwen/Wan)
# -------------------------------------------
# Get your API key from: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# -------------------------------------------
# MIDTRANS PAYMENT GATEWAY (Indonesia)
# -------------------------------------------
# Get your keys from: https://dashboard.midtrans.com/
MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
MIDTRANS_IS_PRODUCTION=false

# -------------------------------------------
# PAYPAL PAYMENT GATEWAY (Global)
# -------------------------------------------
# Get your keys from: https://developer.paypal.com/
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# -------------------------------------------
# APP CONFIGURATION
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
